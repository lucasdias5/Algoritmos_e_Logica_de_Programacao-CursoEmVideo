algoritmo "exercicio-6"
var
   num, antecessor, sucessor: inteiro
inicio
      escreva("Digite um n·mero inteiro: ")
      leia(num)
      antecessor <- num - 1
      sucessor <- num + 1
      escreval("O sucessor de ", num, " ķ ", sucessor)
      escreva("O antecessor de ", num, " ķ ", antecessor)
fimalgoritmo