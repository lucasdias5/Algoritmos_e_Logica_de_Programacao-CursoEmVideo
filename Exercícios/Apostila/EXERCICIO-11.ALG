algoritmo "exercicio-11"
var
   a, b, c, delta: real
inicio
      escreva("Digite o valor de A: ")
      leia(a)
      escreva("Digite o valor de B: ")
      leia(b)
      escreva("Digite o valor de C: ")
      leia(c)
      delta <- b^2-4*a*c
      escreva("O delta desses valores È: ", delta)
fimalgoritmo