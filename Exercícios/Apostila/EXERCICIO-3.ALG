algoritmo "exercicio-3"
var
   nome: caractere
   salario: real
inicio
      escreva("Digite seu nome completo: ")
      leia(nome)
      escreva("Digite seu salario em real: ")
      leia(salario)
      escreva("O funcionario ", nome, " recebeu um salario de ", salario, " em janeiro")
fimalgoritmo