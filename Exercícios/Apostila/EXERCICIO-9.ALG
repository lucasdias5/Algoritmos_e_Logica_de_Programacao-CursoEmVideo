algoritmo "exercicio-9"
var
   dinheiro, valor_dolar: real
   cotacao: inteiro
inicio
      cotacao <- 5
      escreva("Digite um valor em reais para converter em dµlar: ")
      leia(dinheiro)
      valor_dolar <- dinheiro / cotacao
      escreva("Convertendo ", dinheiro, " reais para dµlar, vocõ recebe: ", valor_dolar, " dµlares.")
      
fimalgoritmo