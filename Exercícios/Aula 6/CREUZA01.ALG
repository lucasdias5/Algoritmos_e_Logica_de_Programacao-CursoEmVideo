algoritmo "creuza01"
var
   ano_nascimento, ano_atual, idade: inteiro
inicio
      escreva("Digite o ano que vocę nasceu: ")
      leia(ano_nascimento)
      escreva("Digite o ano que estamos: ")
      leia(ano_atual)
      idade <- ano_atual - ano_nascimento
      escreva("Vocę fará ", idade, " anos.")
fimalgoritmo