 algoritmo "operadores_logicos"
 var
     a, b, c: inteiro
 inicio
       a <- 2
       b <- 3
       c <- 5
       escreva (nao((a=b) ou (c>a)))
 fimalgoritmo
 
 // "E" testa se A e B são verdadeiros
 // "Ou" testa se A ou B são verdadeiros
 // "Não" se A for verdadeira, "não A" é falsa