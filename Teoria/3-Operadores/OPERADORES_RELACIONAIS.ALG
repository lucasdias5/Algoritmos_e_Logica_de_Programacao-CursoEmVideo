algoritmo "operadores_relacionais"
var
  A, B, C: inteiro
inicio
      A <- 2
      B <- 3
      C <- 5
      escreva(1=C%2)
fimalgoritmo


//Operadores relacionais comparam valores e entregam:
//"Verdadeiro" ou "Falso"

// ">" Maior que;
// "<" Menor que;
// ">=" Maior ou igual que;
// "<=" Menor ou igual que;
// "=" Igual a;
// "<>" Diferente de;