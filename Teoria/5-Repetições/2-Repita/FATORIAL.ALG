algoritmo "fatorial"
var
   c, n, f: inteiro
   r: caractere
inicio
repita
      escreva("Digite um nºmero: ")
      leia(n)
      c <- n
      f <- 1
      repita
            f <- f * c
            c <- c - 1
      ate (c < 1)
      escreval("O valor do fatorial de ", n, " Õ igual a ", f)
      escreva("Vocõ quer continuar? [S/N] ")
      leia(r)
ate(r = "N")
      
fimalgoritmo