algoritmo "FuncoesAritmeticas"
var
    valor1: Real
inicio
      valor1 <- Int(RaizQ(90))
      Escreva(valor1)
fimalgoritmo

// Abs: Valor Absoluto
// Exp: Exponenciacao
// Int: Valor Inteiro
// RaizQ: Raiz Quadrada
// Pi: retorna Pi
// Sen: Seno (rad)
// Cos: Cosseno (rad)
// Tan: Tangente (rad)
// GraupRad: Graus para Rad