algoritmo "primeiro" //nome
var  //area de variaveis
  msg: caractere //variavel tipo string
inicio // inicio do algoritmo
  msg <- "Olá, Mundo!" //variável msg recebe "OLá, Mundo!"
  Escreval("Mensagem: ", msg) //print com quebra
  Escreva("Me livrei da maldiçăo!!") //print padrăo
fimalgoritmo