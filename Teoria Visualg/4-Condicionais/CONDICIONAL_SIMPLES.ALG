algoritmo "condicional_simples"
var
   ano, nasc, idade: inteiro
inicio
      escreva("Em que ano estamos: ")
      leia(ano)
      escreva("Em que ano vocę nasaceu: ")
      leia(nasc)
      idade <- ano - nasc
      escreval("Vocę tem/terá: ", idade)
      se(idade >= 18) entao
               escreva("Vocę é/será maior de idade.")
      fimse
fimalgoritmo