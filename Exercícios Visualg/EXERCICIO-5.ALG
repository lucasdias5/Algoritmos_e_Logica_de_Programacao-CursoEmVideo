algoritmo "exercicio-5"
var
   nota1, nota2, media: real
inicio
      escreval("Digite suas notas em Matemática e descubra sua média")
      escreva("Digite sua primeira nota: ")
      leia(nota1)
      escreva("Digite sua segunda nota: ")
      leia(nota2)
      media <- (nota1 + nota2)/2
      escreva("Sua média em Matemática foi: ", media)
fimalgoritmo